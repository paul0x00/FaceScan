{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "vcpkg-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "macos",
      "displayName": "macOS (vcpkg + Ninja)",
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    },
    {
      "name": "windows",
      "displayName": "Windows x64 (vcpkg + Visual Studio 2022)",
      "inherits": "vcpkg-base",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x64-windows" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "system",
      "displayName": "System dependencies (no vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build"
    }
  ],
  "buildPresets": [
    { "name": "macos", "configurePreset": "macos" },
    { "name": "windows", "configurePreset": "windows", "configuration": "Release" },
    { "name": "system", "configurePreset": "system" }
  ],
  "testPresets": [
    {
      "name": "macos",
      "configurePreset": "macos",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows",
      "configurePreset": "windows",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    }
  ]
}
